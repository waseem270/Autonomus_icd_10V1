# Database
DATABASE_URL=sqlite:///database/medical_icd.db

# API Configuration
API_VERSION=v1
API_PREFIX=/api/v1
DEBUG=True
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# File Upload
UPLOAD_MAX_SIZE=26214400
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=.pdf

# LLM Configuration - Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash
GEMINI_MAX_TOKENS=8000
GEMINI_TEMPERATURE=0.0
GEMINI_TIMEOUT=60

# OCR Configuration
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_LANGUAGE=eng
OCR_CONFIG=--psm 6
POPPLER_PATH=

# NLP Configuration
SCISPACY_MODEL=en_core_sci_md
NEGSPACY_ENABLED=True
DISEASE_CONFIDENCE_THRESHOLD=0.7

# MEAT Validation
MEAT_CONFIDENCE_HIGH=0.9
MEAT_CONFIDENCE_MEDIUM=0.7
MEAT_REQUIRE_EVIDENCE=True

# ICD Mapping
ICD_EXACT_MATCH_PRIORITY=True
ICD_FUZZY_THRESHOLD=0.85
ICD_MANUAL_REVIEW_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security (for future)
SECRET_KEY=your-secret-key-change-in-production
